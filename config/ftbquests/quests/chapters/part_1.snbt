					}
					type: "item"
				}
				{
					id: "67E92A531FD08893"
					item: {
						Count: 1
						ForgeCaps: {
							"tfc:item_heat": {
								heat: 0.0f
								ticks: 0L
							}
						}
						id: "tfc:ceramic/unfired_large_vessel"
					}
					type: "item"
				}
			]
			title: "陶器"
			x: 4.5d
			y: 5.5d
		}
		{
			dependencies: ["4B2BF6CBCCF3C23F"]
			description: [
				"&b现在是时候制作一个坑窑来烧制你的陶器了。"
				""
				"坑窑是一种原始加热方法，最高能把物品加热到1400℃。"
				""
				"&e先在地上挖一个一格深的洞，然后按V将陶器放进去："
				""
				"{image:ftbquests:textures/picture/pit_1.png width:100 height:90 align:center}"
				"&e然后按右键放入八个干草："
				"{image:ftbquests:textures/picture/pit_2.png width:100 height:130 align:center}"
				"{@pagebreak}"
				"&e最后放上八个原木："
				"{image:ftbquests:textures/picture/pit_3.png width:100 height:150 align:center}"
				"&e然后通过起火器或火把(丢在坑窑上,等待一会即可点燃）点燃坑窑。"
			]
			hide_until_deps_complete: true
			icon: "tfc:wood/log/oak"
			id: "3B9960C96DD3D684"
			tasks: [
				{
					count: 8L
					id: "7C13C4FB15941BF2"
					item: "tfc:straw"
